
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    match /tools/{toolId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /ad_units/{adId} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /admin_settings/{settingId} {
      // Allow public to read site config and reward ads so they appear for visitors
      allow get: if settingId == 'site_config' || settingId == 'reward_ads' || settingId == 'global_ads' || isAdmin();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /rewarded_ads_library/{adId} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /payments/{paymentId} {
      allow get: if isSignedIn() && isAdmin();
      allow list: if isAdmin();
    }

    match /toolStats/{toolId} {
      allow get, list: if isAdmin();
      allow create, update: if true; 
    }

    match /daily_aggregates/{date} {
      allow get, list: if isAdmin();
      allow create, update: if true;
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn();
      allow list: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    match /shortUrls/{code} {
      allow get: if true;
      allow create: if true;
      allow update: if true;
    }
  }
}
